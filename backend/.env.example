# Google AI Studio key — get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Optional. Defaults to gemini-2.0-flash.
# Other good options: gemini-2.5-flash, gemini-1.5-flash-latest
GEMINI_MODEL=gemini-2.0-flash

# HTTP port
PORT=8080

# SQLite file path
DB_PATH=./makesense.db

# CORS allow-origin for the frontend
ALLOWED_ORIGIN=http://localhost:3000
