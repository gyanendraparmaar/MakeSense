# ---- LLM provider selection ---------------------------------------------
# Recommended: freellmapi — stacks free tiers from 16 providers with automatic
# failover when one is rate-limited. See FREELLMAPI.md for setup.
#
# One of: freellmapi | gemini | groq | openai | openrouter | ollama | openai-compatible
LLM_PROVIDER=freellmapi

# ---- FreeLLMAPI (recommended) ---------------------------------------------
# Start the proxy from repo root: docker compose up -d freellmapi
# Dashboard: http://localhost:3001 — add upstream provider keys there.
# Copy the unified key from the Keys page header.
FREELLMAPI_API_KEY=
FREELLMAPI_BASE_URL=http://localhost:3001/v1
FREELLMAPI_MODEL=auto
# Pin a specific model for better JSON reliability (todo/expenses analyzers):
# FREELLMAPI_MODEL=llama-3.3-70b-versatile

# ---- Groq (direct, single provider) ---------------------------------------
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ---- Gemini (Google AI Studio) --------------------------------------------
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ---- OpenAI ---------------------------------------------------------------
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# ---- OpenRouter -----------------------------------------------------------
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ---- Ollama (local, no key needed) ----------------------------------------
# Run `ollama pull llama3.1:8b` first, then LLM_PROVIDER=ollama
# OLLAMA_MODEL=llama3.1:8b

# ---- Generic OpenAI-compatible endpoint -----------------------------------
# LLM_API_KEY=
# LLM_MODEL=
# LLM_BASE_URL=

# ---- Server ---------------------------------------------------------------
PORT=8080
DB_PATH=./makesense.db
ALLOWED_ORIGIN=http://localhost:3000
