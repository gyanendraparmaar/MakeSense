# ---- LLM provider selection ---------------------------------------------
# One of: gemini | groq | openai | openrouter | ollama | openai-compatible
LLM_PROVIDER=groq

# ---- Groq (recommended: free, fast, OpenAI-compatible) ------------------
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=
# Model. Good options:
#   llama-3.3-70b-versatile  (smartest, ~14.4k req/day free)
#   llama-3.1-8b-instant     (fastest / cheapest)
GROQ_MODEL=llama-3.3-70b-versatile

# ---- Gemini (Google AI Studio) ------------------------------------------
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ---- OpenAI -------------------------------------------------------------
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# ---- OpenRouter ---------------------------------------------------------
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ---- Ollama (local, no key needed) --------------------------------------
# Run `ollama pull llama3.1:8b` first, then LLM_PROVIDER=ollama
# OLLAMA_MODEL=llama3.1:8b

# ---- Generic OpenAI-compatible endpoint (Together, Cerebras, DeepSeek…) -
# LLM_API_KEY=
# LLM_MODEL=
# LLM_BASE_URL=

# ---- Server -------------------------------------------------------------
PORT=8080
DB_PATH=./makesense.db
ALLOWED_ORIGIN=http://localhost:3000
