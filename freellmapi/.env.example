# FreeLLMAPI config — used by the root docker-compose.yml
# Copy to .env and set ENCRYPTION_KEY before starting:
#   cp freellmapi/.env.example freellmapi/.env
#   openssl rand -hex 32   # paste as ENCRYPTION_KEY

# Required: encrypts upstream provider keys at rest (64-char hex)
ENCRYPTION_KEY=your-64-char-hex-key-here

# Server port (default: 3001)
PORT=3001

# Docker only: host interface for published port (default 127.0.0.1)
# HOST_BIND=0.0.0.0

# Max /v1 proxy requests per minute per client IP (default: 120, 0 = off)
# PROXY_RATE_LIMIT_RPM=120

# Extra browser origins for the dashboard (localhost is allowed by default)
# DASHBOARD_ORIGINS=http://my-server.local
